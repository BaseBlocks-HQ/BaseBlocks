    "react-dom": "^19.2.6",
    "react-dropzone": "^14.3.8",
    "react-pdf": "^10.4.1",
    "server-only": "^0.0.1",
    "sonner": "^2.0.7",
    "swr": "^2.4.1",
    "web-haptics": "^0.0.6",
    "yauzl": "^3.3.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@baseblocks/tailwind-config": "workspace:*",
    "@baseblocks/tsconfig": "workspace:*",
    "@types/mdx": "^2.0.13",
    "@types/node": "^25.9.1",
