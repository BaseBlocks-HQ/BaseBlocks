    "@uiw/react-codemirror": "^4.25.10",
    "@vercel/analytics": "^1.6.1",
    "beautiful-mermaid": "1.1.3",
    "better-auth": "^1.6.11",
    "convex": "^1.39.1",
    "docx": "^9.6.1",
    "dompurify": "^3.4.5",
    "fumadocs-core": "16.9.1",
    "fumadocs-mdx": "15.0.8",
    "fumadocs-ui": "16.9.1",
    "geist": "^1.7.1",
    "lucide-react": "^0.577.0",
    "motion": "^12.40.0",
    "nanoid": "^5.1.11",
    "next": "16.2.6",
    "next-intl": "4.12.0",
    "next-themes": "^0.4.6",
