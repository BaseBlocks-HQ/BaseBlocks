{
  "name": "@baseblocks/web",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "scripts": {
    "prepare:pdf-worker": "node ./scripts/copy-pdf-worker.mjs",
    "dev": "bun run prepare:pdf-worker && next dev --port 3001 -H 0.0.0.0",
    "build": "bun run prepare:pdf-worker && next build",
    "start": "next start",
    "lint": "biome check --write .",
    "check-types": "fumadocs-mdx && next typegen && mkdir -p .next/types && (test -f .next/types/cache-life.d.ts || echo 'export {};' > .next/types/cache-life.d.ts) && tsc --noEmit --incremental false"
  },
  "dependencies": {
    "@baseblocks/backend": "workspace:*",
    "@baseblocks/storage": "workspace:*",
    "@baseblocks/types": "workspace:*",
    "@baseblocks/ui": "workspace:*",
    "@blocknote/core": "^0.46.2",
    "@blocknote/mantine": "^0.46.2",
    "@blocknote/react": "^0.46.2",
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language": "^6.12.3",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@convex-dev/better-auth": "^0.12.2",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@napi-rs/canvas": "^1.0.0",
