{
  "name": "@baseblocks/upload-service",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bash -c 'set -a; source ../web/.env.local; set +a; export STORAGE_UPLOAD_ALLOWED_ORIGINS=\"http://localhost:3001\"; bun --watch src/index.ts'",
    "start": "bun src/index.ts",
    "check-types": "tsc --noEmit"
  },
  "dependencies": {
    "@baseblocks/storage": "workspace:*",
    "@baseblocks/types": "workspace:*"
  },
  "devDependencies": {
    "@baseblocks/tsconfig": "workspace:*",
    "@types/node": "^25.9.1",
    "typescript": "5.9.2"
  }
}
