# =============================================================================
# BaseBlocks Environment Variables
# =============================================================================
# Copy the relevant values to:
#   - apps/web/.env.local
#   - packages/backend/.env.local
# =============================================================================

# --- apps/web/.env.local ---

NEXT_PUBLIC_CONVEX_URL=https://your-deployment.convex.cloud
NEXT_PUBLIC_CONVEX_SITE_URL=https://your-deployment.convex.site
NEXT_PUBLIC_ROOT_DOMAIN=localhost:3001

# Optional GitHub token used by product integrations.
GITHUB_TOKEN=

# Files SDK gateway/storage boundary.
FILES_ADAPTER=s3
FILES_BUCKET=user-content
FILES_ENDPOINT=
FILES_REGION=
FILES_FORCE_PATH_STYLE=true
FILES_ACCESS_KEY_ID=
FILES_SECRET_ACCESS_KEY=
FILES_MAX_UPLOAD_SIZE_BYTES=104857600
FILES_API_SECRET=

# Internal Convex -> Next extraction callback.
EXTRACTION_API_SECRET=

# --- packages/backend/.env.local ---

APP_URL=http://localhost:3001
SITE_URL=https://your-deployment.convex.site
CONVEX_DEPLOYMENT=dev:your-deployment-name
CONVEX_URL=https://your-deployment.convex.cloud

BETTER_AUTH_SECRET=

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common

FILES_ADAPTER=s3
FILES_BUCKET=user-content
FILES_ENDPOINT=
FILES_REGION=
FILES_FORCE_PATH_STYLE=true
FILES_ACCESS_KEY_ID=
FILES_SECRET_ACCESS_KEY=
FILES_MAX_UPLOAD_SIZE_BYTES=104857600

EXTRACTION_API_URL=
EXTRACTION_API_SECRET=
