# Auto detect text files and perform LF normalization
* text=auto eol=lf

# Denote all files that are truly binary and should not be modified.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.webp binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.pdf binary

# Ensure shell scripts use LF
*.sh text eol=lf

# Ensure batch scripts use CRLF
*.bat text eol=crlf
*.cmd text eol=crlf

# Lock files - treat as generated
bun.lock linguist-generated
