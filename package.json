{
  "name": "baseblocks",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "node scripts/dev-auth-mode.mjs local",
    "dev:local": "node scripts/dev-auth-mode.mjs local",
    "dev:mobile": "node scripts/dev-auth-mode.mjs mobile",
    "dev:raw": "turbo run dev",
    "start": "cd apps/upload && bun run start",
    "lint": "biome check --write .",
    "format": "biome format --write .",
    "test": "bun test",
    "check-types": "turbo run check-types"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "turbo": "^2.9.4",
    "typescript": "5.9.2"
  },
  "resolutions": {
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "convex": "^1.34.1"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "bun@1.3.1",
  "workspaces": ["apps/*", "packages/*", "tooling/*"],
  "dependencies": {
    "convex": "^1.34.1"
  }
}
