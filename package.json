{
  "name": "baseblocks",
  "private": true,
  "version": "0.0.0",
  "type": "commonjs",
  "license": "MIT",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "check-types": "turbo run check-types",
    "test": "bun test",
    "clean": "rm -rf .turbo apps/*/.next apps/*/.source packages/*/.turbo tooling/*/.turbo"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "turbo": "^2.9.14",
    "typescript": "5.9.2"
  },
  "resolutions": {
    "@convex-dev/better-auth": "0.12.2",
    "@radix-ui/react-presence": "1.1.6",
    "better-auth": "1.6.11",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "convex": "^1.39.1"
  },
  "engines": {
    "node": ">=20.9.0"
  },
  "packageManager": "bun@1.3.14",
  "workspaces": [
    "apps/*",
    "packages/*",
    "tooling/*"
  ],
  "dependencies": {}
}
