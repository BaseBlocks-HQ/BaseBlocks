{
  "name": "baseblocks",
  "private": true,
  "version": "0.0.0",
  "type": "commonjs",
  "license": "MIT",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "check-types": "turbo run check-types",
    "test": "bun test",
    "clean": "rm -rf .turbo apps/*/.next apps/*/.source packages/*/.turbo tooling/*/.turbo"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.3",
    "@typescript/native-preview": "npm:typescript@7.0.2",
    "turbo": "^2.10.4",
    "typescript": "7.0.2"
  },
  "resolutions": {
    "@convex-dev/better-auth": "0.12.5",
    "@radix-ui/react-presence": "1.1.6",
    "better-auth": "1.6.23",
    "defu": "6.1.7",
    "picomatch": "4.0.5",
    "postcss": "8.5.16",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "convex": "^1.42.1"
  },
  "engines": {
    "node": ">=20.9.0"
  },
  "packageManager": "bun@1.3.14",
  "workspaces": [
    "apps/*",
    "packages/*",
    "tooling/*"
  ],
  "dependencies": {}
